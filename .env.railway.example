# Railway Environment Variables Template
# Copy values and set in Railway dashboard or via CLI

# ─── PostgreSQL (auto-generated by Railway) ───
# Format: postgresql://user:password@host:port/database
DATABASE_URL=

# ─── Python Gateway (ibor-ai-gateway) ───
ANTHROPIC_API_KEY=your-anthropic-api-key-here
PG_DSN=${DATABASE_URL}

# ─── Java Middleware (ibor-middleware) ───
SPRING_DATASOURCE_URL=${DATABASE_URL}
SPRING_DATASOURCE_USERNAME=your-db-user
SPRING_DATASOURCE_PASSWORD=your-db-password

# ─── React Frontend (ibor-ui) ───
VITE_API_URL=https://ibor-ai-gateway-prod.railway.app
VITE_MIDDLEWARE_URL=https://ibor-middleware-prod.railway.app

# ─── Optional: Railway-specific ───
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PRIVATE_DOMAIN_SUFFIX=railway.internal
