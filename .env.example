# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this to .env and fill in actual values for your environment
# ─────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 1: CLOSED BETA (Email Whitelist + Shared API Key)
# ═══════════════════════════════════════════════════════════════════════════════
ENVIRONMENT=beta

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED SECRETS (must be set via environment variables or .env)
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API key for LLM calls
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL connection string
PG_DSN=postgresql://user:password@localhost:5432/ibor

# ─────────────────────────────────────────────────────────────────────────────
# 1. RATE LIMITING (per IP per minute)
# ─────────────────────────────────────────────────────────────────────────────

# Enable rate limiting (true for production, false for development)
RATE_LIMIT_ENABLED=true

# Requests per minute per IP
RATE_LIMIT_RPM=30

# ─────────────────────────────────────────────────────────────────────────────
# 2. AUTHENTICATION (Email Whitelist for Closed Beta)
# ─────────────────────────────────────────────────────────────────────────────

# Enable email whitelist (Phase 1: closed beta)
EMAIL_WHITELIST_ENABLED=true

# Comma-separated list of allowed email addresses
# Used for authorization check in /analyst/chat endpoint
EMAIL_WHITELIST=user1@example.com,user2@example.com,team@example.com

# ─────────────────────────────────────────────────────────────────────────────
# 3. QUOTAS (Daily usage limits)
# ─────────────────────────────────────────────────────────────────────────────

# Maximum questions per IP per day
MAX_QUESTIONS_PER_DAY=100

# Maximum tokens (estimated) per IP per day
MAX_TOKENS_PER_DAY=500000

# ─────────────────────────────────────────────────────────────────────────────
# 4. COST CONTROLS (OpenAI API spending limits)
# ─────────────────────────────────────────────────────────────────────────────

# Enable cost tracking and enforcement
COST_TRACKING_ENABLED=true

# Maximum daily spend in USD (hard stop when exceeded)
# Phase 1: $50/day limit for closed beta
MAX_DAILY_SPEND_USD=50.0

# ─────────────────────────────────────────────────────────────────────────────
# 5. INPUT VALIDATION
# ─────────────────────────────────────────────────────────────────────────────

# Maximum question length in characters
MAX_QUESTION_LENGTH=2000

# Minimum question length in characters
MIN_QUESTION_LENGTH=10

# Comma-separated list of banned keywords
# Example: sql,delete,drop,exec,script
BANNED_KEYWORDS=

# ─────────────────────────────────────────────────────────────────────────────
# 6. MONITORING & LOGGING
# ─────────────────────────────────────────────────────────────────────────────

# Log all requests (true for production)
LOG_ALL_REQUESTS=true

# Alert on quota violations (true to log warnings)
ALERT_ON_QUOTA_VIOLATION=true

# ═══════════════════════════════════════════════════════════════════════════════
# SERVICE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Spring Boot API base URL (IBOR middleware)
STRUCTURED_API_BASE=http://localhost:8080/api

# Verify SSL certificates (false for development, true for production)
VERIFY_SSL=false

# Anthropic model to use
ANTHROPIC_MODEL=claude-opus-4-6

# OpenAI embedding model (for RAG)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ═══════════════════════════════════════════════════════════════════════════════
# RAILWAY.APP DEPLOYMENT SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Set PORT for Railway (defaults to 8000)
# PORT=8000

# Railway PostgreSQL variables (auto-set, but can override):
# DATABASE_URL=postgresql://...

# For Railway:
# 1. Set these environment variables in Railway dashboard
# 2. Use railway link postgresql to auto-populate DATABASE_URL
# 3. Push secrets (ANTHROPIC_API_KEY, EMAIL_WHITELIST) via Railway CLI
#    railway variables set ANTHROPIC_API_KEY=... EMAIL_WHITELIST=...
